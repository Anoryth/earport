msgid "Disabled"
msgstr "Вимкнено"

#: extension/prefs.js:186
msgid "When one earbud removed"
msgstr "Коли вийнято один навушник"

#: extension/prefs.js:187
msgid "When both earbuds removed"
msgstr "Коли вийнято обидва навушники"

#: extension/prefs.js:190
msgid "Auto-pause media"
msgstr "Автопауза медіа"

#: extension/prefs.js:191
msgid "Pause playback when earbuds are removed"
msgstr "Призупиняти відтворення, коли навушники вийнято з вух"

#: extension/prefs.js:198
msgid "Notifications"
msgstr "Сповіщення"

#: extension/prefs.js:199
msgid "Configure notification preferences"
msgstr "Налаштуйте параметри сповіщень"

#: extension/prefs.js:204
msgid "Connection notifications"
msgstr "Сповіщення про підключення"

#: extension/prefs.js:205
msgid "Notify when AirPods connect or disconnect"
msgstr "Сповіщати про підключення або відключення AirPods"

#: extension/prefs.js:210
msgid "Low battery notifications"
msgstr "Сповіщення про низький заряд"

#: extension/prefs.js:211
msgid "Notify when battery drops below threshold"
msgstr "Сповіщати, коли рівень заряду падає нижче порогу"

#: extension/prefs.js:216
msgid "Low battery threshold"
msgstr "Поріг низького заряду"

#: extension/prefs.js:217
msgid "Notify when battery drops below this percentage"
msgstr "Сповіщати, коли заряд батареї опускається нижче цього відсотка"

#: extension/prefs.js:229
msgid "Keyboard Shortcuts"
msgstr "Комбінації клавіш"

#: extension/prefs.js:239
msgid "Cycle noise control mode"
msgstr "Перемикання режиму керування шумом"

#: extension/prefs.js:240
msgid "Also works when the Quick Settings menu is closed"
msgstr "Також працює, коли меню швидких налаштувань закрито"

#: extension/prefs.js:255
msgid "About"
msgstr "Про програму"

