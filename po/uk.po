msgstr "Додати режим \"Шумозаглушення\" до циклу довгого натискання"

#: extension/prefs.js:173
msgid "Include Adaptive mode in long press cycle"
msgstr "Додати режим \"Адаптивний\" до циклу довгого натискання"

#: extension/prefs.js:179
msgid "Media Control"
msgstr "Керування медіа"

