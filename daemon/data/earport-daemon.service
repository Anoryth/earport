[Unit]
Description=EarPort AirPods Daemon
Documentation=https://github.com/Anoryth/earport
After=bluetooth.target

[Service]
Type=dbus
BusName=io.github.anoryth.EarPort
ExecStart=/usr/local/bin/earport-daemon
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.config/earport
PrivateTmp=true

[Install]
WantedBy=default.target
